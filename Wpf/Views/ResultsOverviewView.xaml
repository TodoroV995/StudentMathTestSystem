<UserControl x:Class="Wpf.Views.ResultsOverviewView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Grid Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Text="Results Overview"
                   FontSize="26"
                   FontWeight="Bold"
                   VerticalAlignment="Center"/>

            <Button Grid.Column="1"
                Content="Refresh"
                Width="100"
                Height="30"
                Command="{Binding RefreshCommand}"/>
        </Grid>

        <!-- RESULTS GRID -->
        <DataGrid Grid.Row="1"
              ItemsSource="{Binding Results}"
              AutoGenerateColumns="False"
              IsReadOnly="True"
              CanUserSortColumns="True"
              SelectionMode="Single">

            <DataGrid.Columns>
                <DataGridTextColumn Header="Result Id" Binding="{Binding Id}" Width="90"/>
                <DataGridTextColumn Header="Student Id" Binding="{Binding StudentId}" Width="100"/>
                <DataGridTextColumn Header="Test Id" Binding="{Binding MathTestId}" Width="100"/>
                <DataGridTextColumn Header="Score" Binding="{Binding Score}" Width="100"/>
                <DataGridTextColumn Header="Total Questions" Binding="{Binding TotalQuestions}" Width="130"/>
                <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="120"/>
                <DataGridTextColumn Header="Started At" Binding="{Binding StartedAt}" Width="180"/>
                <DataGridTextColumn Header="Completed At" Binding="{Binding CompletedAt}" Width="180"/>
            </DataGrid.Columns>

        </DataGrid>
    </Grid>
</UserControl>