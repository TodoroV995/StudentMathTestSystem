<UserControl x:Class="Wpf.Views.TeacherUploadView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Margin="20">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- TITLE -->
        <TextBlock Text="Teacher XML Upload"
                   FontSize="26"
                   FontWeight="Bold"
                   Margin="0,0,0,20"/>

        <!-- XML UPLOAD -->
        <GroupBox Grid.Row="1"
                  Header="Upload Exam XML"
                  Margin="0,0,0,15">

            <StackPanel Margin="10">

                <TextBlock Text="Selected XML file:"
                           Margin="0,0,0,5"/>

                <TextBox Text="{Binding SelectedXmlFilePath}"
                         IsReadOnly="True"
                         Margin="0,0,0,10"
                         Height="28"/>

                <StackPanel Orientation="Horizontal">

                    <Button Content="Browse XML"
                            Width="120"
                            Height="30"
                            Margin="0,0,10,0"
                            Command="{Binding BrowseXmlCommand}"/>

                    <Button Content="Upload and Process"
                            Width="160"
                            Height="30"
                            Command="{Binding UploadAndProcessCommand}"/>

                </StackPanel>

                <!-- STATUS -->
                <TextBlock Text="{Binding StatusMessage}"
                           Margin="0,10,0,0"
                           FontWeight="SemiBold"
                           TextWrapping="Wrap"/>

            </StackPanel>
        </GroupBox>

        <!-- SUMMARY -->
        <GroupBox Grid.Row="2"
                  Header="Processing Summary"
                  Margin="0,0,0,15">

            <UniformGrid Columns="4"
                         Margin="10">

                <StackPanel>
                    <TextBlock Text="Students"
                               FontWeight="Bold"/>
                    <TextBlock Text="{Binding ProcessedStudentsCount}"
                               FontSize="20"/>
                </StackPanel>

                <StackPanel>
                    <TextBlock Text="Exams"
                               FontWeight="Bold"/>
                    <TextBlock Text="{Binding ProcessedExamsCount}"
                               FontSize="20"/>
                </StackPanel>

                <StackPanel>
                    <TextBlock Text="Correct Tasks"
                               FontWeight="Bold"/>
                    <TextBlock Text="{Binding CorrectTasksCount}"
                               FontSize="20"/>
                </StackPanel>

                <StackPanel>
                    <TextBlock Text="Incorrect Tasks"
                               FontWeight="Bold"/>
                    <TextBlock Text="{Binding IncorrectTasksCount}"
                               FontSize="20"/>
                </StackPanel>

            </UniformGrid>
        </GroupBox>

        <!-- PROCESSED RESULTS -->
        <GroupBox Grid.Row="3"
          Header="Processed Exam Results">

            <DataGrid ItemsSource="{Binding ProcessedResults}"
              AutoGenerateColumns="False"
              IsReadOnly="True"
              CanUserSortColumns="True"
              Margin="10">

                <DataGrid.Columns>
                    <DataGridTextColumn Header="Student Id"
                                Binding="{Binding StudentId}"
                                Width="100"/>

                    <DataGridTextColumn Header="Exam Id"
                                Binding="{Binding ExamId}"
                                Width="100"/>

                    <DataGridTextColumn Header="Total Tasks"
                                Binding="{Binding TotalTasks}"
                                Width="120"/>

                    <DataGridTextColumn Header="Correct Tasks"
                                Binding="{Binding CorrectTasks}"
                                Width="130"/>

                    <DataGridTextColumn Header="Score %"
                                Binding="{Binding ScorePercentage, StringFormat={}{0:0.##}%}"
                                Width="100"/>
                </DataGrid.Columns>

            </DataGrid>

        </GroupBox>

    </Grid>
</UserControl>