<Window x:Class="Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:Wpf.Views"
        Title="Student Math Test System"
        Height="650"
        Width="1000"
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F5">

    <Grid>
        <TabControl Margin="10">

            <!-- TEACHER MAIN TAB -->
            <TabItem Header="Teacher">
                <TabControl Margin="10">

                    <TabItem Header="Students">
                        <!--<Grid Margin="20">
                            <TextBlock Text="Student Management"
                                       FontSize="26"
                                       FontWeight="Bold" />
                        </Grid>-->
                        <views:StudentManagementView/>
                    </TabItem>

                    <TabItem Header="XML Upload">
                        <views:TeacherUploadView />
                    </TabItem>

                    <TabItem Header="Results Overview">
                        <views:ResultsOverviewView />
                    </TabItem>

                </TabControl>
            </TabItem>

            <!-- STUDENT MAIN TAB -->
            <TabItem Header="Student Analytics">
                <views:StudentAnalyticsView />
            </TabItem>

        </TabControl>
    </Grid>
</Window>